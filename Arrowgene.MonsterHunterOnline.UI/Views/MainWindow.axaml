<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Arrowgene.MonsterHunterOnline.UI.ViewModels"
        xmlns:controls="using:Arrowgene.MonsterHunterOnline.UI.Components"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
        x:Class="Arrowgene.MonsterHunterOnline.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1440"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        Background="#EEE8DD"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="TabControl#MainTabs">
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style Selector="TabControl#MainTabs > TabItem">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Foreground" Value="#64748B" />
        </Style>
        <Style Selector="TabControl#MainTabs > TabItem:selected">
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="TabControl#MainTabs > TabItem:pointerover">
            <Setter Property="Foreground" Value="#334155" />
        </Style>
        <Style Selector="TabControl#MainTabs > TabItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>
        <Style Selector="TabControl#MainTabs > TabItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="#334155" />
        </Style>
    </Window.Styles>

    <TabControl x:Name="MainTabs">
        <TabItem Header="IIPS Archive Explorer">
            <controls:IIPSArchiveFileExplorer />
        </TabItem>
        <TabItem Header="Level Map Viewer">
            <controls:LevelMapViewer />
        </TabItem>
        <TabItem Header="Quest Viewer">
            <controls:QuestViewer />
        </TabItem>
    </TabControl>

</Window>
