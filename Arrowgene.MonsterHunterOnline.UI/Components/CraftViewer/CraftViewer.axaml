<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:Arrowgene.MonsterHunterOnline.UI.Components"
             x:Class="Arrowgene.MonsterHunterOnline.UI.Components.CraftViewer"
             x:DataType="local:CraftViewerViewModel"
             mc:Ignorable="d">

    <Design.DataContext>
        <local:CraftViewerViewModel />
    </Design.DataContext>

    <UserControl.Resources>
        <SolidColorBrush x:Key="FgPrimary" Color="#0F172A" />
        <SolidColorBrush x:Key="FgSecondary" Color="#334155" />
        <SolidColorBrush x:Key="FgMuted" Color="#667085" />
        <SolidColorBrush x:Key="FgOnDark" Color="#F9FAFB" />
        <SolidColorBrush x:Key="BgPage" Color="#F2F1EC" />
        <SolidColorBrush x:Key="BgPane" Color="#F8F7F4" />
        <SolidColorBrush x:Key="BgSurface" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BgSurfaceAlt" Color="#ECE9E2" />
        <SolidColorBrush x:Key="BgBar" Color="#E8E5DE" />
        <SolidColorBrush x:Key="BgDark" Color="#111827" />
        <SolidColorBrush x:Key="BgInput" Color="#1F2937" />
        <SolidColorBrush x:Key="BorderDefault" Color="#D7D3CC" />
        <SolidColorBrush x:Key="BorderSubtle" Color="#E2E8F0" />
        <SolidColorBrush x:Key="BorderDark" Color="#374151" />
        <SolidColorBrush x:Key="Splitter" Color="#DDD9D1" />
        <SolidColorBrush x:Key="TagOutputBg" Color="#E8E5DE" />
        <SolidColorBrush x:Key="TagOutputFg" Color="#3D3929" />
        <SolidColorBrush x:Key="TagMatBg" Color="#EDE9E0" />
        <SolidColorBrush x:Key="TagMatFg" Color="#4A4330" />
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Border.pane">
            <Setter Property="Background" Value="{StaticResource BgPane}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDefault}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="12" />
        </Style>
        <Style Selector="Border.pill">
            <Setter Property="Background" Value="{StaticResource BgSurfaceAlt}" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource BgSurface}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource FgMuted}" />
        </Style>
        <Style Selector="TextBlock.pill-text">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource FgSecondary}" />
        </Style>
        <Style Selector="TextBlock.detail-label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource FgMuted}" />
            <Setter Property="MinWidth" Value="100" />
        </Style>
        <Style Selector="TextBlock.detail-value">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource FgPrimary}" />
            <Setter Property="Margin" Value="0,14,0,4" />
        </Style>
        <Style Selector="Button.toolbar-text">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="34" />
        </Style>

        <!-- Item row with icon -->
        <Style Selector="Border.item-row">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,3" />
        </Style>
    </UserControl.Styles>

    <Border Background="{StaticResource BgPage}">
        <DockPanel LastChildFill="True">

            <!-- ═══ Filter bar ═══ -->
            <Border DockPanel.Dock="Top" Background="{StaticResource BgBar}"
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,0,0,1"
                    Padding="16,8" IsVisible="{Binding HasRecipes}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBox Text="{Binding FilterText, Mode=TwoWay}"
                             Watermark="Search by ID or name..."
                             Width="220" MinHeight="28" Padding="8,4" FontSize="11" />

                    <TextBlock Text="Equipment:" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgSecondary}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding EquipFilters}"
                              SelectedItem="{Binding SelectedEquipFilter}"
                              MinHeight="28" Padding="8,4" FontSize="11" />

                    <TextBlock Text="Type:" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgSecondary}" VerticalAlignment="Center" />
                    <ComboBox ItemsSource="{Binding TypeFilters}"
                              SelectedItem="{Binding SelectedTypeFilter}"
                              MinHeight="28" Padding="8,4" FontSize="11" />

                    <Border Width="1" Height="20" Background="{StaticResource BorderDark}" VerticalAlignment="Center" />

                    <Border Classes="pill">
                        <TextBlock Text="{Binding Recipes.Count, StringFormat='{}{0} recipes'}" Classes="pill-text" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- ═══ Status bar ═══ -->
            <Border DockPanel.Dock="Bottom" Background="{StaticResource BgPane}"
                    BorderBrush="{StaticResource BorderDefault}" BorderThickness="0,1,0,0" Padding="12,8">
                <TextBlock Text="{Binding StatusText}" MaxLines="1" TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource FgSecondary}" ToolTip.Tip="{Binding StatusText}" />
            </Border>

            <!-- ═══ Main content ═══ -->
            <Grid ColumnDefinitions="350,6,*" MinHeight="0">

                <!-- ── Recipe list ── -->
                <Border Grid.Column="0" Classes="pane" Margin="12,12,6,12" MinHeight="0">
                    <Grid RowDefinitions="Auto,*" MinHeight="0">
                        <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
                            <TextBlock Text="Recipes" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource FgPrimary}" />
                            <TextBlock Text="{Binding Recipes.Count, StringFormat='{}{0} recipes loaded'}"
                                       Classes="caption" />
                        </StackPanel>
                        <Border Grid.Row="1" Background="{StaticResource BgSurface}"
                                BorderBrush="{StaticResource BorderDefault}" BorderThickness="1"
                                CornerRadius="10" Padding="4" MinHeight="0">
                            <ListBox ItemsSource="{Binding Recipes}"
                                     SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                                     Background="Transparent" BorderThickness="0" MinHeight="0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:CraftListItemViewModel">
                                        <StackPanel Margin="4,3">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Id, StringFormat='#{0}'}"
                                                           Foreground="{StaticResource FgMuted}" FontSize="11"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource FgPrimary}" FontSize="13" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Summary}"
                                                       Foreground="{StaticResource FgMuted}" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="6" Background="{StaticResource Splitter}"
                              ShowsPreview="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <!-- ── Recipe detail ── -->
                <Border Grid.Column="2" Classes="pane" Margin="0,12,12,12" MinHeight="0">
                    <ScrollViewer IsVisible="{Binding HasSelection}">
                        <StackPanel Spacing="4" Margin="4">

                            <!-- Name + badges -->
                            <TextBlock Text="{Binding DetailName}" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource FgPrimary}" TextWrapping="Wrap" />
                            <WrapPanel Orientation="Horizontal" Margin="0,4,0,8">
                                <Border Classes="pill" Margin="0,0,8,4">
                                    <TextBlock Text="{Binding DetailId, StringFormat='Recipe #{0}'}" Classes="pill-text" />
                                </Border>
                                <Border Classes="pill" Margin="0,0,8,4"
                                        IsVisible="{Binding DetailEquipType, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding DetailEquipType}" Classes="pill-text" />
                                </Border>
                                <Border Classes="pill" Margin="0,0,8,4">
                                    <TextBlock Text="{Binding DetailRecipeType}" Classes="pill-text" />
                                </Border>
                                <Border Classes="pill" Margin="0,0,8,4"
                                        IsVisible="{Binding DetailSourceSheet, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding DetailSourceSheet}" Classes="pill-text" />
                                </Border>
                            </WrapPanel>

                            <!-- Properties -->
                            <TextBlock Classes="section-title" Text="Requirements" />
                            <Border Classes="card">
                                <Grid ColumnDefinitions="Auto,*,Auto,*" RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8" RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="detail-label" Text="Level" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Classes="detail-value"
                                               Text="{Binding DetailRequiredLevel}" />
                                    <TextBlock Grid.Row="0" Grid.Column="2" Classes="detail-label" Text="Star" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" Classes="detail-value"
                                               Text="{Binding DetailRequiredStar}" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="detail-label" Text="Gold Cost" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Classes="detail-value"
                                               Text="{Binding DetailGoldCost, StringFormat='{}{0}z'}" />
                                </Grid>
                            </Border>

                            <!-- Outputs -->
                            <TextBlock Classes="section-title" Text="Output" />
                            <ItemsControl ItemsSource="{Binding DetailOutputs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:CraftOutputViewModel">
                                        <Border Classes="item-row" Background="{StaticResource TagOutputBg}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Image Source="{Binding Icon}" Width="32" Height="32"
                                                       IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                       VerticalAlignment="Center" />
                                                <StackPanel VerticalAlignment="Center" Spacing="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TagOutputFg}" />
                                                        <TextBlock Text="{Binding Count, StringFormat='x{0}'}"
                                                                   FontSize="12" Foreground="{StaticResource FgMuted}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource FgMuted}">
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="ID: {0}  |  Rate: {1}%">
                                                                <Binding Path="ItemId" />
                                                                <Binding Path="Rate" />
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Byproduct -->
                            <TextBlock Classes="section-title" Text="Byproduct"
                                       IsVisible="{Binding HasByproduct}" />
                            <Border Classes="item-row" Background="{StaticResource BgSurfaceAlt}"
                                    IsVisible="{Binding HasByproduct}">
                                <StackPanel Orientation="Horizontal" Spacing="10"
                                            DataContext="{Binding DetailByproduct}">
                                    <Image Source="{Binding Icon}" Width="32" Height="32"
                                           IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                           VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center" Spacing="1">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource FgSecondary}" />
                                            <TextBlock Text="{Binding Count, StringFormat='x{0}'}"
                                                       FontSize="12" Foreground="{StaticResource FgMuted}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                        <TextBlock FontSize="11" Foreground="{StaticResource FgMuted}">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="ID: {0}  |  Rate: {1}%">
                                                    <Binding Path="ItemId" />
                                                    <Binding Path="Rate" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Materials -->
                            <TextBlock Classes="section-title" Text="Materials" />
                            <ItemsControl ItemsSource="{Binding DetailMaterials}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="local:CraftMaterialViewModel">
                                        <Border Classes="item-row" Background="{StaticResource TagMatBg}">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Image Source="{Binding Icon}" Width="32" Height="32"
                                                       IsVisible="{Binding Icon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                       VerticalAlignment="Center" />
                                                <StackPanel VerticalAlignment="Center" Spacing="1">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TagMatFg}" />
                                                        <TextBlock Text="{Binding Count, StringFormat='x{0}'}"
                                                                   FontSize="12" FontWeight="Bold"
                                                                   Foreground="{StaticResource FgSecondary}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding ItemId, StringFormat='ID: {0}'}"
                                                               FontSize="11" Foreground="{StaticResource FgMuted}" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
